{
  "name": "enigmagent-mcp",
  "version": "1.0.5",
  "mcpName": "io.github.Agnuxo1/enigmagent-mcp",
  "private": false,
  "files": [
    "index.js",
    "vault-core.js",
    "README.md"
  ],
  "description": "Local encrypted vault MCP server. AES-256-GCM + Argon2id. Resolves {{PLACEHOLDER}} secrets at runtime so LLMs never see real API keys. Works with Claude Desktop, Cursor, Continue.dev, Cline, Open WebUI.",
  "type": "module",
  "bin": {
    "enigmagent-mcp": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "start:rest": "node index.js --mode rest --port 3737",
    "start:mcp": "node index.js --mode mcp"
  },
  "dependencies": {
    "@noble/hashes": "1.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
