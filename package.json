{
  "name": "enigmagent-mcp",
  "version": "1.0.0",
  "private": false,
  "files": ["index.js", "vault-core.js", "README.md"],
  "description": "EnigmAgent MCP server — exposes your encrypted vault as an MCP tool for Open WebUI, AnythingLLM, LM Studio and any MCP-compatible AI agent.",
  "type": "module",
  "bin": {
    "enigmagent-mcp": "./index.js"
  },
  "scripts": {
    "start":       "node index.js",
    "start:rest":  "node index.js --mode rest --port 3737",
    "start:mcp":   "node index.js --mode mcp"
  },
  "dependencies": {
    "@noble/hashes": "1.4.0"
  },
  "engines": { "node": ">=18" },
  "keywords": ["mcp", "ai-agents", "vault", "secrets", "enigmagent", "open-webui", "anythingllm"],
  "author": "Francisco Angulo de Lafuente <agnuxo1@gmail.com>",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/agnuxo1/EnigmAgent" }
}
